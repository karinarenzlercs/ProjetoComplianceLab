# ===================================================================
# .env.example — Modelo de configuração (PODE ser commitado)
# Copie este arquivo para ".env" e preencha com a sua chave real.
#   Windows (PowerShell):  Copy-Item .env.example .env
# Obtenha uma chave gratuita em: https://aistudio.google.com/app/apikey
# ===================================================================

GEMINI_API_KEY=cole_sua_chave_aqui

# (Opcional) Modelo do Gemini. Padrão: gemini-2.5-flash.
# Use um modelo Flash disponível na sua chave. Ex.: gemini-2.5-flash, gemini-flash-latest.
# GEMINI_MODEL=gemini-2.5-flash
